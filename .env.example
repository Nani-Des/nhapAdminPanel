# Optional: override Google AI (Gemini) API base URL (no trailing slash). Dev server proxies /google-ai-api by default.
# VITE_GOOGLE_AI_API_BASE=https://your-proxy.example.com

# Optional: Gemini model (default: gemini-2.0-flash)
# VITE_GEMINI_MODEL=gemini-1.5-flash

# Set to "true" only for debugging — prints google_ai_studio_api from Remote Config in the browser console.
# VITE_DEBUG_PRINT_AI_KEY=true
